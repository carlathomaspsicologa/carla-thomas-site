---
layout: base.njk
---
<article class="section editorial">
  <div class="wrap" style="max-width:760px">
    <p class="kicker">Blog{% if date %} · {{ date | dataBR }}{% endif %}</p>
    <h1>{{ title }}</h1>
    <p class="post-meta-line">{{ categoria }}<span class="dot">·</span>{{ tempoLeitura }} de leitura</p>
    <div class="post-content">
      {{ content | safe }}
    </div>
    <div class="btn-row" style="margin-top:40px">
      <a class="btn btn--ghost" href="/blog.html">← Voltar ao blog</a>
      <a class="btn btn--whats" href="https://wa.me/5551998281716?text=Ol%C3%A1%2C%20Carla!%20Vim%20pelo%20site%20e%20gostaria%20de%20agendar%20um%20atendimento." target="_blank" rel="noopener">Falar no WhatsApp</a>
    </div>
  </div>
</article>
