<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — Carla Thomas{% else %}Carla Thomas — Psicóloga{% endif %}</title>
{% if resumo %}<meta name="description" content="{{ resumo }}">{% endif %}
<link rel="canonical" href="https://carlagabriellethomas.com{{ page.url }}">
<meta property="og:type" content="{% if categoria %}article{% else %}website{% endif %}">
<meta property="og:title" content="{% if title %}{{ title }}{% else %}Carla Thomas — Psicóloga{% endif %}">
{% if resumo %}<meta property="og:description" content="{{ resumo }}">{% endif %}
<meta property="og:url" content="https://carlagabriellethomas.com{{ page.url }}">
<meta property="og:image" content="https://carlagabriellethomas.com/assets/img/carla-hero.jpg">
<meta property="og:locale" content="pt_BR">
<meta property="og:site_name" content="Carla Thomas — Psicóloga">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{% if title %}{{ title }}{% else %}Carla Thomas — Psicóloga{% endif %}">
{% if resumo %}<meta name="twitter:description" content="{{ resumo }}">{% endif %}
<meta name="twitter:image" content="https://carlagabriellethomas.com/assets/img/carla-hero.jpg">
{% if categoria %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ resumo }}",
  "datePublished": "{{ date | dataISO }}",
  "author": { "@type": "Person", "name": "Carla Gabrielle Thomas", "jobTitle": "Psicóloga" },
  "publisher": { "@type": "Person", "name": "Carla Gabrielle Thomas" },
  "mainEntityOfPage": "https://carlagabriellethomas.com{{ page.url }}",
  "articleSection": "{{ categoria }}",
  "inLanguage": "pt-BR"
}
</script>
{% endif %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Montserrat:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/style.css">
</head>
<body>
<header class="site-header">
  <div class="wrap nav">
    <a class="brand" href="/index.html">Carla Thomas<small>Psicóloga</small></a>
    <button class="nav-toggle" aria-label="Abrir menu">☰</button>
    <ul class="menu">
      <li><a href="/index.html">Início</a></li>
      <li><a href="/sobre.html">Sobre</a></li>
      <li><a href="/psicoterapia.html">Psicoterapia</a></li>
      <li><a class="active" href="/blog.html">Blog</a></li>
      <li><a href="/ebook.html">E-book</a></li>
      <li><a href="/materiais.html">Materiais</a></li>
      <li><a href="/contato.html">Contato</a></li>
    </ul>
  </div>
</header>

{{ content | safe }}

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <a class="brand" href="/index.html">Carla Gabrielle Thomas</a>
      <p class="crp">Psicóloga CRP: 07/32377 | Mestre em Psicologia e Saúde</p>
    </div>
    <div><h4>Navegação</h4>
      <ul class="footer-links">
        <li><a href="/sobre.html">Sobre</a></li>
        <li><a href="/psicoterapia.html">Psicoterapia</a></li>
        <li><a href="/blog.html">Blog</a></li>
        <li><a href="/materiais.html">Materiais</a></li>
      </ul></div>
    <div><h4>Contato</h4>
      <ul class="footer-links">
        <li><a href="https://instagram.com/carlagabriellethomas" target="_blank" rel="noopener">@carlagabriellethomas</a></li>
        <li><a href="mailto:carlathomaspsicologa@gmail.com">carlathomaspsicologa@gmail.com</a></li>
      </ul></div>
  </div>
  <div class="footer-bottom">© <span data-year>2026</span> Carla Gabrielle Thomas · Psicóloga CRP 07/32377 · Todos os direitos reservados.</div>
</footer>
<script src="/assets/nav.js"></script>
</body>
</html>
